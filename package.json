{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "preinstall": "node -e \"['package-lock.json','yarn.lock'].forEach(f=>{try{require('fs').unlinkSync(f)}catch{}});if(!process.env.npm_config_user_agent?.startsWith('pnpm/')){console.error('Use pnpm instead');process.exit(1)}\"",
    // "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build": "pnpm --filter ./artifacts/api-server run build"
    "typecheck:libs": "tsc --build",
    // "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
    "typecheck": "pnpm run typecheck:libs && pnpm --filter ./artifacts/api-server --if-present run typecheck"
    "typecheck": "pnpm --filter ./artifacts/api-server --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.3",
    "@rollup/rollup-win32-x64-msvc": "^4.60.2",
    "lightningcss-win32-x64-msvc": "1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
